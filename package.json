{
  "name": "gigaprompt-tower-defense",
  "version": "0.1.0",
  "description": "GigaPrompt Tower Defense (GPTD) — a pixel tower-defense management game where you defend an AI serving platform from waves of user requests.",
  "type": "module",
  "license": "MIT",
  "author": "JacobLinCool",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "e2e": "node scripts/screenshot.mjs",
    "bridge": "node public/bridge.mjs"
  },
  "dependencies": {
    "pixi.js": "^8.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "globals": "^17.6.0",
    "playwright": "^1.60.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
